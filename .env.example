# Copy to .env before running Docker Compose.
# SIYUAN_ACCESS_AUTH_CODE and SIYUAN_API_TOKEN must be the same secure random value.
SIYUAN_ACCESS_AUTH_CODE=replace-with-a-32-plus-character-random-token
SIYUAN_API_TOKEN=replace-with-the-same-value-as-SIYUAN_ACCESS_AUTH_CODE

# Gateway JWT settings. Use a long random JWT_SECRET and mint SIYUAN_GATEWAY_TOKEN with matching issuer/audience.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=tripp-mind
JWT_AUDIENCE=tripp-fleet
SIYUAN_GATEWAY_TOKEN=replace-with-a-jwt-signed-by-JWT_SECRET
SIYUAN_BOT_GATEWAY_TOKEN=
SIYUAN_BACKUP_GATEWAY_TOKEN=
DASHBOARD_CORS_ORIGIN=*

# Gateway and service ports.
GATEWAY_PORT=3000
EVENT_BRIDGE_PORT=3001
EVENT_BRIDGE_AUTH_TOKEN=
EVENT_BRIDGE_HEARTBEAT_MS=30000

# Backup service.
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_RETENTION_COUNT=14
BACKUP_RUN_ON_STARTUP=true

# Telegram bot. Leave TELEGRAM_ALLOWED_CHAT_IDS empty to allow all chats.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Discord bot. DISCORD_GUILD_ID is optional; omit for global slash command registration.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=

# Bot note target. Leave empty to use the first open notebook.
SIYUAN_DEFAULT_NOTEBOOK=

# Optional SiYuan/event bridge advanced settings.
SIYUAN_X_AUTH_TOKEN=
EVENT_BRIDGE_INCLUDE_RAW=false
EVENT_BRIDGE_RECONNECT_MIN_MS=1000
EVENT_BRIDGE_RECONNECT_MAX_MS=30000
